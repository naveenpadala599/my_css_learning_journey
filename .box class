/*Universal selector*/
*{
  margin: 1px;
  padding: 1px;
  border: 0px dashed red;
  box-sizing: border-box;
}
/*root variables*/
:root{
  --main-color: #6c63ff;
  --accent: #ff6584;
  --bg: #0000ff;
  --text:#ffffff;  
}
body{
  font-family: Arial, sans-serif;
  background: var(--bg);
  color: var(--text);
  line-height: 1.9;  
}
h1{
  text-align: center;
  letter-spacing: 4px;
  text-transform: uppercase;
  text-shadow: -2px 5px 6px orange;
}
h2{
  margin: 40px;
  color: var(--accent)
}
.box{
  width: 200px;
  height: 200px;
  margin: 40px;
  padding: 20px;
  border: 5px solid white;
  background: var(--main-color);
  
  

}
