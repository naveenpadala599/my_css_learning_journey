<!DOCTYPE html>
<html lang="en">
 <head>
  <meta charset="UTF-8">
  <title>Flexbox Power Demo</title>
  <style>
    *{
     margin: 0px;
     padding: 0px;
     box-sizing: border-box;
     font-family: Arial, Helvetica, sans-serif;
    }
    body{
     background: #0f172a; 
     color: white;
     padding: 30px;
    }
    h1{
     text-align: center;
     margin-bottom: 30px;
    }
    .box{
     background: #22c55e;
     padding: 20px;
     border-radius: 20px;
     text-align: center;
     font-weight: bold;
    }
    section{
     margin-bottom: 20px;
    }
    .demo{
     border: 2px dashed #475569;
     padding: 20px;
     border-radius: 15px;
     margin-top:15px;
    }
    .row{
     display: flex;
     gap: 15px;
    }
    .center{
     display: flex;
     justify-content: center;
     align-items: center;
     height: 200px;
    }
    .space{
     display: flex;
     justify-content: space-between;
    }
    .grow{
     display: flex;
     gap: 10px;
    }
    .grow .box:nth-child(2){
     flex:2
    }
    .wrap{
     display: flex;
     flex-wrap: wrap;
     gap: 10px;
    }
    .wrap .box{
     flex: 1 1 150px;
    }
    .order{
     display: flex;
     gap: 10px;
    }
    .order .first{ order:3; background: #f43f5e;}
    .order .second{ order:1; background:#3b82f6;}
    .order .third{ order:2; background:#eab308;}
    .navbar{
     display: flex;
     justify-content: space-between;
     align-items:center;
     background:#1e293b;
     padding: 15px 20px;
     border-radius: 10px;
    }
    .nav-links{
     display: flex;
     gap: 20px;
    }
    .nav-links div{
     cursor:pointer;
     transition:.9s;
    }
    .nav-links div:hover{
     color:#22c55e;
    }
    .cards{
     display: flex;
     gap:20px;
    }
    .card{
     flex:1;
     background:#1e293b;
     padding:20px;
     border-radius: 12px;
    }
  </style>
 </head>
 <body>
  <h1>⚡ FLEXBOX SUPERPOWERS ⚡ </h1>
  <section>
   <h2>1️⃣ Simple Row</h2>
   <div class="demo row">
    <div class="box">1</div>
    <div class="box">2</div> 
    <div class="box">3</div> 
   </div>
  </section>
  <section>
   <h2>2️⃣ Perfect Centring (The Magic)</h2>
   <div class="demo center">
    <div class="box">I am perfectly centered 😎</div>
   </div>
  </section>
  <section>
   <h2>3️⃣ Space Between</h2>
   <div class="demo space">
    <div class="box">Left</div>
    <div class="box">Right</div>
   </div>
  </section> 
  <section>
   <h2>4️⃣ Flex Grow (Middle Expands)</h2>
   <div class="demo grow">
    <div class="box">Small</div> 
    <div class="box">I Grow</div> 
    <div class="box">Small</div> 
   </div>
  </section>
  <section>
  <h2>5️⃣ Resoponsive Wrapping</h2> 
  <div class="demo wrap">
   <div class="box">1</div>
   <div class="box">2</div>
   <div class="box">3</div>
   <div class="box">4</div>
   <div class="box">5</div>
   <div class="box">6</div>
  </div>
  </section>
  <section>
  <h2>6️⃣ Reordering Without Changing HTML</h2>
  <div class="demo order">
   <div class="box first">HTML First</div> 
   <div class="box second">HTML Second</div>  
   <div class="box third">HTML Third</div>  
  </div>
  </section>
  <section>
   <h2>7️⃣ Real Navbar Layout</h2>
   <div class="navbar">
    <div>LOGO</div>
    <div class="nav-links">
     <div>Home</div> 
     <div>About</div> 
     <div>Contact</div>
      </div>
    </div>
  </section> 
   
  <section>
  <h2>8️⃣ Card Layout</h2>
  <div class="cards">
    <div class="card">Card 1 content</div>
    <div class="card">Card 2 content</div>
    <div class="card">Card 3 content</div> 
    </div>
  </section>
 </body>
</html>
