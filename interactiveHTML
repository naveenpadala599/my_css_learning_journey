<!DOCTYPE html>
<html lang="en">
  <head>
   <meta charset="UTF-8">
   <meta name="viewport" content="width=device-width, initial-scale=1.0">
   <title>Ultimate Interactive Elements Demo</title>
   <style>
     
   </style>
   
  </head>
  <body>
   <div class="container">
   <h1>🔥 Interactive HTML Playground</h1>
   <div class="card">
   <h2>Form Elements</h2>
     
   <label>Name</label>
   <input type="text" placeholder="Enter name">
     
   <label>Password</label>
   <input type="password" placeholder="Password">
     
   <label>Date</label>
   <input type="date">
     
   <label>Color Picker</label>
   <input type="color">
     
   <label>Upload File</label>
   <input type="file">
     
   <label>Textarea</label>
   <textarea rows="4"></textarea>
     
   <label>Dropdown</label>
   <select>
    <option>Option 1</option>
    <option>Option 2</option> 
    <option>Option 3</option> 
   </select>
   </div>

   
   <div class="card">
   <h2>Radio & Checkbox</h2>
   
   <p>Gender:</p>
   <input type="radio" name="g">Male
   <input type="radio" name="g">Female
   
   <br><br>
     
   <input type="checkbox"> Subscribe to newsletter
     
   </div>
   <div class="card">
   <h2>Buttons</h2>
   <button class="btn primary">Primary</button>
   <button class="btn success">Success</button>
   <button class="btn danger">Danger</button>
   </div>
   <div class="card">
   <h2>Toggle Switch</h2>
   <label class="switch">
   <input type="checkbox">
   <span class="slider"></span>
   </label>
   </div>
   
   <div class="card">
   <h2>Range & Progress</h2>
   <input type="range">
   <br><br>
   <progress value="60" max="100"></progress>
   </div>
   
   <div class="card">
    <h2>Accordion</h2>
    <details>
    <summary>Click to expand</summary>
    <p>This is hidden content 😄</p>
    </details>
   </div>
     
   <div class="card">
   <h2>Audio Player</h2>
   <audio controls>
   <source src="https://www.w3schools.com/horse.mp3">  
   </audio>
   </div>
   <div class="card">
   <h2>Video Player</h2>
   <video width="100%" controls>
   <source src="https://www.w3schools.com/html/mov_bbb.mp4">  
   </video>
   </div>
   <div class="card">
   <h2>PDF Viewer</h2>
   <iframe src="https://www.w3.org/WAI/ER/tests/xhtml/testfiles/resources/pdf/dummy.pdf"></iframe>
   </div>
   <div class="card">
   <h2>Table</h2>
   <table>
   <tr><th>Name</th><th>Age</th></tr>
   <tr><td>John</td><td>25</td></tr>
   <tr><td>Jane</td><td>28</td></tr>
   </table>
   </div>
   </div>   
  </body>
</html>  
