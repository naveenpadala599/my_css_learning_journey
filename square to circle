<!DOCTYPE html>
<html>
<head>
<style>

body{
  height:100vh;
  display:flex;
  justify-content:center;
  align-items:center;
  background:black;
}

.box{
  width:120px;
  height:120px;
  background:cyan;

  transition:0.4s;
}

.box:hover{
  transform:rotate(45deg) scale(1.2);
  border-radius:50%;
}

</style>
</head>
<body>

<div class="box"></div>

</body>
</html>
