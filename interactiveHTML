<!DOCTYPE html>
<html lang="en">
  <head>
   <meta charset="UTF-8">
   <meta name="viewport" content="width=device-width, initial-scale=1.0">
   <title>Ultimate Interactive Elements Demo</title>
   <style>
        *{
     margin:0;
     padding:0;
     box-sizing:border-box;
     font-family:Segoe UI, sans-serif;
     } 
     body{
     background:linear-gradient(120deg,#0f172a,#020617);
     color:white;
     padding:40px;
     }
     .container
     {
     max-width:1100px;
     margin:auto;
     }
     h1{
     text-align:center;
     margin-bottom:30px;
     font-size:40px;
     }
     .card{
     background:#111827;
     padding:25px;
     margin-bottom:25px;
     border-radius:16px;
     box-shadow:0 0 25px;
     }
     input, select, textarea{
     width:100%;
     padding:10px;
     border-radius:8px;
     border:none;
     margin-top:1px;
     margin-bottom:15px;
     }
     .btn{
     padding:12px;
     border:none;
     border-radius:100%;
     cursor:pointer;
     font-weight:bold;
     margin:5px;
     transition:.3s
     }
     .primary{ background:#6366f1; color: white;}
     .success{ background:#10b981; color:white;}
     .danger{ background:#ef4444; color:white;}
     .btn:hover{ transform:scale(1.05);}
     .switch{
     position:relative;
     display:inline-block;
     width:60px;
     height:34px;
     }
     .switch input{ display:none;}
     .slider{
     position:absolute;
     cursor:pointer;
     inset:0;
     background:#ccc;
     border-radius:34px;
     transition:.4s;
     }
     .slider:before{
     content:"";
     position:absolute;
     height:26px; width:26px;
     left:4px; bottom:4px;
     background:white;
     border-radius:50%;
     transition:.4s;
     }
     input:checked+.slider{
      background:#22c55e;
     }
     input:checked+.slider:before{
     transform:translateX(26pX);
     } 

       progress{
     width:100%;
     height:20px;
     }
     table{
     width:100%;
     border-collapse:collapse;
     }
     td,th{
     padding:10px;
     border-bottom:1px solid white;
     }
     input[type=range]{accent-color:#6366f1;
     }
     iframe{
     width:100%;
     height:500px;
     border:none;
     border-radius:10px;
     }
     
   </style>
   
  </head>
  <body>
   <div class="container">
   <h1>🔥 Interactive HTML Playground</h1>
   <div class="card">
   <h2>Form Elements</h2>
     
   <label>Name</label>
   <input type="text" placeholder="Enter name">
     
   <label>Password</label>
   <input type="password" placeholder="Password">
     
   <label>Date</label>
   <input type="date">
     
   <label>Color Picker</label>
   <input type="color">
     
   <label>Upload File</label>
   <input type="file">
     
   <label>Textarea</label>
   <textarea rows="4"></textarea>
     
   <label>Dropdown</label>
   <select>
    <option>Option 1</option>
    <option>Option 2</option> 
    <option>Option 3</option> 
   </select>
   </div>

   
   <div class="card">
   <h2>Radio & Checkbox</h2>
   
   <p>Gender:</p>
   <input type="radio" name="g">Male
   <input type="radio" name="g">Female
   
   <br><br>
     
   <input type="checkbox"> Subscribe to newsletter
     
   </div>
   <div class="card">
   <h2>Buttons</h2>
   <button class="btn primary">Primary</button>
   <button class="btn success">Success</button>
   <button class="btn danger">Danger</button>
   </div>
   <div class="card">
   <h2>Toggle Switch</h2>
   <label class="switch">
   <input type="checkbox">
   <span class="slider"></span>
   </label>
   </div>
   
   <div class="card">
   <h2>Range & Progress</h2>
   <input type="range">
   <br><br>
   <progress value="60" max="100"></progress>
   </div>
   
   <div class="card">
    <h2>Accordion</h2>
    <details>
    <summary>Click to expand</summary>
    <p>This is hidden content 😄</p>
    </details>
   </div>
     
   <div class="card">
   <h2>Audio Player</h2>
   <audio controls>
   <source src="https://www.w3schools.com/horse.mp3">  
   </audio>
   </div>
   <div class="card">
   <h2>Video Player</h2>
   <video width="100%" controls>
   <source src="https://www.w3schools.com/html/mov_bbb.mp4">  
   </video>
   </div>
   <div class="card">
   <h2>PDF Viewer</h2>
   <iframe src="https://www.w3.org/WAI/ER/tests/xhtml/testfiles/resources/pdf/dummy.pdf"></iframe>
   </div>
   <div class="card">
   <h2>Table</h2>
   <table>
   <tr><th>Name</th><th>Age</th></tr>
   <tr><td>John</td><td>25</td></tr>
   <tr><td>Jane</td><td>28</td></tr>
   </table>
   </div>
   </div>   
  </body>
</html>  
