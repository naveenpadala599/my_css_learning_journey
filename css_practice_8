<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Flex Container Practice</title>

    <style>
     .container{
        display: flex;
        flex-direction: row;
        flex-wrap: wrap;
        justify-content: space-evenly;
        border: 2px solid black;
        height: 300px;
        align-items: flex-end;
        align-content: space-evenly;
        width: 180px;
        column-gap:10px;
        margin-bottom: 10px;
      
      }
            
      
    </style>
</head>
<body>

    <h1>Flex Container Practice</h1>

    <section class="container">
        <div class="item">Item 1</div>
        <div class="item">Item 2</div>
        <div class="item">Item 3</div>
        <div class="item">Item 4</div>
        <div class="item">Item 5</div>
        <div class="item">Item 6</div>
        <div class="item">Item 7</div>
        <div class="item">Item 8</div>
        <div class="item">Item 9</div>
        <div class="item">Item 10</div>
    </section>
  
    <section class="container" style="display: flex; align-items: baseline; align-content: flex-end;">
        <div class="item">Small</div>
        <div class="item"><h1>BIG</h1></div>
        <div class="item">Medium</div>
    </section>

</body>
</html>
