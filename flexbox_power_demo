<!DOCTYPE html>
<html lang="en">
 <head>
  <meta charset="UTF-8">
  <title>Flexbox Power Demo</title>
  <style>
    *{
     margin: 0px;
     padding: 0px;
     box-sizing: border-box;
     font-family: Arial, Helvetica, sans-serif;
    }
    body{
     background: #0f172a; 
     color: white;
     padding: 30px;
    }
    h1{
     text-align: center;
     margin-bottom: 30px;
    }
    .box{
     background: #22c55e;
     padding: 20px;
     border-radius: 20px;
     text-align: center;
     font-weight: bold;
    }
    section{
     margin-bottom: 20px;
    }
    .demo{
     border: 2px dashed #475569;
     padding: 20px;
     border-radius: 15px;
     margin-top:15px;
    }
    .row{
     display: flex;
     gap: 15px;
    }
    .center{
     display: flex;
     justify-content: center;
     align-items: center;
     height: 200px;
    }
    .space{
     display: flex;
     justify-content: space-between;
    }
    .grow{
     display: flex;
     gap: 10px;
    }
    .grow .box:nth-child(2){
     flex:2
    } 
  </style>
 </head>
 <body>
  <h1>⚡ FLEXBOX SUPERPOWERS ⚡ </h1>
  <section>
   <h2>1️⃣ Simple Row</h2>
   <div class="demo row">
    <div class="box">1</div>
    <div class="box">2</div> 
    <div class="box">3</div> 
   </div>
  </section>
  <section>
   <h2>2️⃣ Perfect Centring (The Magic)</h2>
   <div class="demo center">
    <div class="box">I am perfectly centered 😎</div>
   </div>
  </section>
  <section>
   <h2>3️⃣ Space Between</h2>
   <div class="demo space">
    <div class="box">Left</div>
    <div class="box">Right</div>
   </div>
  </section> 
  <section>
   <h2>4️⃣ Flex Grow (Middle Expands)</h2>
   <div class="demo grow">
    <div class="box">Small</div> 
    <div class="box">I Grow</div> 
    <div class="box">Small</div> 
   </div>
  </section>
 </body>
</html>
